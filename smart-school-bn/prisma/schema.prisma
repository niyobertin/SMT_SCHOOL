generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id                   String    @id @default(cuid())
  email                String?   @unique
  phoneNumber          String?   @unique
  username             String    @unique
  firstName            String
  lastName             String
  password             String
  role                 UserRole  @default(STUDENT)
  avatar               String?
  isActive             Boolean   @default(true)
  isVerified           Boolean   @default(false)
  verificationCode     Int?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  lastLogin            DateTime?

  // Relations
  courses            Course[]
  enrollments        Enrollment[]
  payments           Payment[]
  testAttempts       TestAttempt[]
  userProgress       UserProgress[]
  userCourseProgress UserCourseProgress[]
  notifications      Notification[]
  ActivityLog        ActivityLog[]

  @@map("users")
}

enum UserRole {
  ADMIN
  INSTRUCTOR
  STUDENT
}

// Course Management
model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  slug        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  courses Course[]

  @@map("categories")
}

model Course {
  id               String       @id @default(cuid())
  title            String
  slug             String       @unique
  description      String
  shortDescription String?
  thumbnail        String?
  language         String       @default("en")
  level            CourseLevel  @default(BEGINNER)
  status           CourseStatus @default(DRAFT)
  isPublished      Boolean      @default(false)
  isFeatured       Boolean      @default(false)
  type             String?      @default("free")
  tags             String[]
  requirements     String[]
  objectives       String[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  publishedAt      DateTime?

  // Relations
  instructorId String
  instructor   User     @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  lessons            Lesson[]
  enrollments        Enrollment[]
  tests              Test[]
  notifications      Notification[]
  userCourseProgress UserCourseProgress[]
  Payment            Payment[]
  PaymentCourse      PaymentCourse[]

  @@map("courses")
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int
  isPreview   Boolean  @default(false)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  content      LessonContent[]
  userProgress UserProgress[]

  @@map("lessons")
}

model LessonContent {
  id       String  @id @default(cuid())
  title    String?
  textBody String?

  videoUrl String?
  audioUrl String?
  pdfUrl   String?
  imageUrl String?

  fileName  String?
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_content")
}

model Enrollment {
  id                String           @id @default(cuid())
  enrollmentDate    DateTime         @default(now())
  completionDate    DateTime?
  progress          Float            @default(0)
  status            EnrollmentStatus @default(ACTIVE)
  enrollementPeriod Int              @default(30)
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId          String
  course            Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  SUSPENDED
  CANCELLED
  EXPIRED
}

model Payment {
  id                 String          @id @default(cuid())
  amount             Float
  currency           String          @default("RWF")
  status             PaymentStatus   @default(PENDING)
  channel            String
  paypackRef         String?
  subscriptionPeriod Int             @default(30)
  remainingPeriod    Int             @default(0)
  isActive           Boolean         @default(false)
  courses            PaymentCourse[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  // Relations
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course[]

  @@map("payments")
}

model PaymentCourse {
  paymentId String
  courseId  String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([paymentId, courseId])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

// Testing System
model Test {
  id                 String   @id @default(cuid())
  title              String
  description        String?
  instructions       String[]
  type               TestType @default(GENERAL)
  duration           Int?
  passingScore       Float    @default(70)
  maxAttempts        Int?     @default(10)
  isActive           Boolean  @default(true)
  showResults        Boolean  @default(true)
  randomizeQuestions Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  questions     Question[]
  testAttempts  TestAttempt[]
  notifications Notification[]

  @@map("tests")
}

enum TestType {
  PSYCHOMETRIC
  OPENENDED
  INTERVIEW
  GENERAL
}

model Question {
  id          String       @id @default(cuid())
  question    String
  image       String?
  type        QuestionType @default(MULTIPLE_CHOICE)
  points      Float        @default(1)
  explanation String?
  order       Int
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  options QuestionOption[]
  answers Answer[]

  @@map("questions")
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
  FILL_BLANK
}

model QuestionOption {
  id        String   @id @default(cuid())
  option    String
  isCorrect Boolean  @default(false)
  order     Int
  createdAt DateTime @default(now())

  // Relations
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_options")
}

model TestAttempt {
  id             String            @id @default(cuid())
  startTime      DateTime          @default(now())
  endTime        DateTime?
  score          Float?
  totalQuestions Int
  correctAnswers Int               @default(0)
  status         TestAttemptStatus @default(IN_PROGRESS)
  timeSpent      Int? // in minutes
  isPassed       Boolean           @default(false)

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  answers       Answer[]
  notifications Notification[]

  @@map("test_attempts")
}

enum TestAttemptStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
  TIME_UP
}

model Answer {
  id              String   @id @default(cuid())
  answerText      String?
  selectedOptions String[] // for multiple choice
  userAnswer      String[] // for multiple choice
  isCorrect       Boolean?
  points          Float    @default(0)
  createdAt       DateTime @default(now())

  // Relations
  testAttemptId String
  testAttempt   TestAttempt @relation(fields: [testAttemptId], references: [id], onDelete: Cascade)
  questionId    String
  question      Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answers")
}

// Progress Tracking
model UserProgress {
  id           String    @id @default(cuid())
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  timeSpent    Int       @default(0) // in seconds
  lastAccessed DateTime  @default(now())
  bookmarkTime Int? // for video/audio content in seconds

  // Relations
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("user_progress")
}

model UserCourseProgress {
  id             String    @id @default(cuid())
  isCompleted    Boolean   @default(false)
  completedAt    DateTime?
  lastAccessed   DateTime  @default(now())
  completedTests String[]  @default([])

  // Relations
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("user_course_progress")
}

// Notification System
model Notification {
  id        String             @id @default(cuid())
  title     String
  message   String
  type      NotificationType
  status    NotificationStatus @default(UNREAD)
  metadata  Json? // For storing additional data like courseId, testId, etc.
  readAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  testId      String?
  test        Test?         @relation(fields: [testId], references: [id], onDelete: Cascade)
  TestAttempt TestAttempt[]

  @@index([userId, status])
  @@map("notifications")
}

enum NotificationType {
  COURSE_ENROLLMENT
  COURSE_COMPLETION
  TEST_GRADED
  TEST_REMINDER
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  SYSTEM_ALERT
  COURSE_UPDATE
  NEW_COURSE
  PROMOTIONAL
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
  DELETED
}

model JobPost {
  id              String       @id @default(cuid())
  title           String
  slug            String       @unique
  description     String
  dueDate         DateTime
  companyname     String?
  companylogo     String?
  companywebsite  String?
  applicationLink String?
  attachments     String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  jobCategory     JobCategory? @relation(fields: [jobCategoryId], references: [id], onDelete: Cascade)
  jobCategoryId   String?

  @@map("job_posts")
}

model JobCategory {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String    @unique
  jobPosts  JobPost[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("job_categories")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())
}

model YouTubeToken {
  id          String    @id @default(uuid())
  provider    String    @default("youtube")
  credentials String
  expiryDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// EXAMINATION SYSTEM MODELS
// ============================================

// Organization/Institution Management
model Organization {
  id           String   @id @default(cuid())
  name         String
  description  String?
  logo         String?
  contactEmail String?
  contactPhone String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  exams      Exam[]
  candidates Candidate[]

  @@map("organizations")
}

// Candidate Management (separate from User)
model Candidate {
  id             String       @id @default(cuid())
  candidateId    String       @unique // User-friendly ID for login
  firstName      String
  lastName       String
  email          String?
  phoneNumber    String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  examAssignments ExamAssignment[]
  examAttempts    ExamAttempt[]

  @@index([organizationId])
  @@map("candidates")
}

// Standalone Exam (independent of courses)
model Exam {
  id                 String       @id @default(cuid())
  title              String
  description        String?
  instructions       String[]
  duration           Int? // in minutes
  passingScore       Float        @default(70)
  examCode           String       @unique // Unique code for candidate access
  startDate          DateTime?
  endDate            DateTime?
  maxAttempts        Int?         @default(3)
  randomizeQuestions Boolean      @default(true)
  showResults        Boolean      @default(true)
  allowReview        Boolean      @default(true) // Allow candidate to review answers
  isActive           Boolean      @default(true)
  status             ExamStatus   @default(DRAFT)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  questions   ExamQuestion[]
  assignments ExamAssignment[]
  attempts    ExamAttempt[]

  @@index([organizationId])
  @@index([examCode])
  @@map("exams")
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  CLOSED
}

// Exam Questions (separate from course questions)
model ExamQuestion {
  id          String           @id @default(cuid())
  question    String
  image       String?
  type        ExamQuestionType @default(MULTIPLE_CHOICE)
  points      Float            @default(1)
  explanation String?
  order       Int
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  examId      String
  exam        Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)

  // Relations
  options ExamQuestionOption[]
  answers ExamAnswer[]

  @@index([examId])
  @@map("exam_questions")
}

enum ExamQuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
  FILL_BLANK
}

// Answer Options for Exam Questions
model ExamQuestionOption {
  id             String       @id @default(cuid())
  option         String
  isCorrect      Boolean      @default(false)
  order          Int
  createdAt      DateTime     @default(now())
  examQuestionId String
  examQuestion   ExamQuestion @relation(fields: [examQuestionId], references: [id], onDelete: Cascade)

  @@index([examQuestionId])
  @@map("exam_question_options")
}

// Exam Assignment (links candidates to exams)
model ExamAssignment {
  id          String    @id @default(cuid())
  isActive    Boolean   @default(true)
  assignedAt  DateTime  @default(now())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  examId      String
  exam        Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  allowRetake Boolean   @default(false)

  @@unique([candidateId, examId])
  @@index([candidateId])
  @@index([examId])
  @@map("exam_assignments")
}

// Exam Attempt Records
model ExamAttempt {
  id             String            @id @default(cuid())
  startTime      DateTime          @default(now())
  endTime        DateTime?
  score          Float?
  totalQuestions Int
  correctAnswers Int               @default(0)
  status         ExamAttemptStatus @default(IN_PROGRESS)
  timeSpent      Int? // in seconds
  isPassed       Boolean           @default(false)
  candidateId    String
  candidate      Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  examId         String
  exam           Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)

  // Relations
  answers ExamAnswer[]

  @@index([candidateId])
  @@index([examId])
  @@map("exam_attempts")
}

enum ExamAttemptStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
  TIME_UP
}

// Candidate Answers
model ExamAnswer {
  id              String       @id @default(cuid())
  answerText      String?
  selectedOptions String[] // for multiple choice
  userAnswer      String[] // for display
  isCorrect       Boolean?
  points          Float        @default(0)
  timeSpent       Int? // time spent on this question in seconds
  createdAt       DateTime     @default(now())
  examAttemptId   String
  examAttempt     ExamAttempt  @relation(fields: [examAttemptId], references: [id], onDelete: Cascade)
  examQuestionId  String
  examQuestion    ExamQuestion @relation(fields: [examQuestionId], references: [id], onDelete: Cascade)

  @@index([examAttemptId])
  @@index([examQuestionId])
  @@map("exam_answers")
}
